{
  "action_manifest_version": 0,
  "category": "steamvr_input",
  "controller_type": "vive_controller",
  "description": "Default OSC Grimoire bindings for Vive wands.",
  "name": "OSC Grimoire Vive",
  "bindings": {
    "/actions/main": {
      "poses": [
        {
          "output": "/actions/main/in/left_pose",
          "path": "/user/hand/left/pose/tip"
        },
        {
          "output": "/actions/main/in/right_pose",
          "path": "/user/hand/right/pose/tip"
        }
      ],
      "sources": [
        {
          "path": "/user/hand/left/input/application_menu",
          "mode": "button",
          "inputs": {}
        },
        {
          "path": "/user/hand/right/input/application_menu",
          "mode": "button",
          "inputs": {}
        },
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/main/in/left_trigger"
            }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/main/in/left_grip"
            }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/main/in/right_trigger"
            }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/main/in/right_grip"
            }
          }
        }
      ],
      "chords": [
        {
          "inputs": [
            [
              "/user/hand/left/input/application_menu",
              "single"
            ],
            [
              "/user/hand/right/input/application_menu",
              "single"
            ]
          ],
          "output": "/actions/main/in/ui_toggle"
        }
      ]
    }
  }
}
